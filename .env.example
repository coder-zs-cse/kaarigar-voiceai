# --- registration gate (throwaway: no DB) ---
# true  = registered path: the LLM converses
# false = unregistered path: static "please register on WhatsApp" line, then hang up
USER_REGISTERED=true

# --- your public ngrok https URL, no trailing slash (used to build the wss:// stream URL) ---
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# --- which media format the carrier speaks: exotel | twilio | telnyx | plivo ---
TELEPHONY_PROVIDER=exotel

# --- LLM provider: gemini | openai ---
LLM_PROVIDER=gemini

# --- AI service keys ---
GOOGLE_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
SARVAM_API_KEY=your-sarvam-api-key

# --- optional model / voice knobs ---
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_VOICE=anushka

# --- customer inbound agent (Priya) / caller-context API ---
CUSTOMER_INBOUND_AGENT_ID=customer_inbound
CALLER_CONTEXT_URL=https://karigaar-backend.onrender.com/caller-context
CALLER_CONTEXT_TOKEN=kaarigar-ingest-secret-2024
